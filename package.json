{
  "name": "verket-umea",
  "version": "1.0.0",
  "private": true,
  "description": "Official website for Verket Umeå — a non-profit creative space for music, gaming and alternative culture.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
