# =============================================================
# Verket Umeå — miljövariabler
# Kopiera denna fil till .env.local för lokal utveckling.
# I produktion sätts samma variabler i Vercel → Project Settings → Environment Variables.
# =============================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, never exposed to the browser. Used by
# src/lib/supabase/admin.ts for privileged operations (view counters,
# role changes, Google Calendar import). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by `npm run db:types` to regenerate src/types/database.types.ts
SUPABASE_PROJECT_ID=your-project-ref

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://verketumea.se

# --- Admin bootstrap ---
# The account that signs up with this email is automatically promoted
# to 'admin' on first login (see supabase/migrations/0002_functions_triggers.sql
# and supabase/seed.sql). Change this before your first deploy if needed —
# further admins can then be added from the Admin Panel → Users.
ADMIN_BOOTSTRAP_EMAIL=richard.x.bostrom@gmail.com

# --- OAuth providers (configured in Supabase Auth settings, mirrored here
#     for local `supabase start` and for reference in CI secrets) ---
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_DISCORD_CLIENT_ID=
SUPABASE_AUTH_DISCORD_SECRET=

# --- GitHub Actions / Vercel deploy secrets (set these in GitHub repo
#     Settings → Secrets and variables → Actions, not in this file) ---
# VERCEL_TOKEN=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
